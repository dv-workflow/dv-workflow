# ============================================================================
# dw-kit — .gitignore
# ============================================================================
# All .dw/ content is committed — tasks, context, docs, metrics, reports.
# Everyone (team / community) shares the same context.

# Local overrides
CLAUDE.local.md
.claude/settings.local.json
*.local.yml
*.local.yaml

# OS & Editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Node.js
node_modules/
package-lock.json

# Logs
*.log

# Projects refer
projects-refer/*

# Local test / scratch
.tmp/

# Local telemetry (per-dev, auto-created by hooks)
.dw/metrics/events.jsonl