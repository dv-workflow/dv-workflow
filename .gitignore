# ============================================================================
# dw-kit — .gitignore
# ============================================================================
# All .dw/ content is committed — tasks, context, docs, metrics, reports.
# Everyone (team / community) shares the same context.

# Local overrides
CLAUDE.local.md
.claude/settings.local.json
*.local.yml
*.local.yaml

# OS & Editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Node.js
node_modules/
package-lock.json

# Logs
*.log

# Projects refer
projects-refer/*

# Local test / scratch
.tmp/
.smoke-test-tmp/
.smoke-e2e-tmp/
packages/dw-kit-render/test/.tmp/

# Local telemetry (per-dev, auto-created by hooks) — match anywhere
**/.dw/metrics/events.jsonl

# Machine-local OSV snapshot cache (regenerated by `dw security-scan --update-db`)
.dw/security/advisory-snapshot.json

# Review render artifacts — ephemeral per-machine (ADR-0007)
# Regenerated by `/dw:review --visual` → `dw review render`.
.dw/reviews/