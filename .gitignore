# ============================================================================
# dv-workflow-kit — .gitignore
# ============================================================================
# Runtime directories (tạo bởi dw init trong project thực)
# Uncommit .dw/tasks/ nếu muốn track task docs trong git (recommended cho team)
.dw/tasks/
.dw/docs/
.dw/metrics/
.dw/reports/

# Local overrides
CLAUDE.local.md
.claude/settings.local.json
*.local.yml
*.local.yaml

# OS & Editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Node.js
node_modules/
package-lock.json

# Logs
*.log
